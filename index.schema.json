{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/glyph-md/plugins/main/index.schema.json",
  "title": "Glyph plugin marketplace index",
  "type": "object",
  "required": [
    "plugins"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/entry"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "entry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "apiVersion",
        "mainUrl"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
          "description": "Unique reverse-DNS id; also the install folder name."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Plugin semver; must increase when mainUrl changes."
        },
        "apiVersion": {
          "type": "string",
          "pattern": "^\\^?\\d+\\.\\d+\\.\\d+$",
          "description": "Glyph plugin-API range, exact or caret, e.g. ^1.0.0."
        },
        "mainUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://",
          "description": "HTTPS URL to the built single-file ES module, pinned to a tag or commit."
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Capabilities the plugin declares; shown to users in the install consent prompt."
        }
      }
    }
  }
}
